# ═══════════════════════════════════════════════════════════════════════════════
# JARVIS Frontend Environment
# These are the ONLY variables the frontend uses.
# NO provider secrets. NO backend service URLs except the public gateway.
# ═══════════════════════════════════════════════════════════════════════════════

VITE_API_BASE_URL=http://localhost:8000/api
VITE_WS_BASE_URL=ws://localhost:8000/ws
VITE_APP_VERSION=0.1.0
VITE_CLIENT_VERSION=0.1.0
VITE_ENABLE_GPU_UI=true
VITE_ENABLE_WEBGL_VISUALS=true
VITE_ENABLE_WEBGPU_VISUALS=true
VITE_ENABLE_PERFORMANCE_MODE=true
