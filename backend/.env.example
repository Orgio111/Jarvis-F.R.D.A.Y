# ═══════════════════════════════════════════════════════════════════════════════
# JARVIS Backend Environment
# Copy this file to .env and fill in your values.
# Missing provider keys result in provider_unavailable status, not startup failure.
# ═══════════════════════════════════════════════════════════════════════════════

# ─── App ──────────────────────────────────────────────────────────────────────
APP_ENV=development
APP_NAME=jarvis-backend
APP_HOST=0.0.0.0
APP_PORT=8000
API_PREFIX=/api

# ─── Go Gateway ───────────────────────────────────────────────────────────────
GO_GATEWAY_ENABLED=true
GO_GATEWAY_HOST=0.0.0.0
GO_GATEWAY_PORT=8000

# ─── Internal Services ────────────────────────────────────────────────────────
PYTHON_AI_SERVICE_URL=http://python-ai-service:8100
RUST_BROKER_URL=http://rust-broker:8200

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── AI Providers ─────────────────────────────────────────────────────────────
# Leave blank to mark provider as unavailable (no startup failure)
NVIDIA_NIM_API_KEY=your-nvidia-nim-api-key-here
NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1

OPENROUTER_API_KEY=your-openrouter-api-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ─── Provider Routing ─────────────────────────────────────────────────────────
AI_PROVIDER_PRIMARY=nvidia_nim
AI_PROVIDER_FALLBACK=openrouter
AI_PROVIDER_ROUTING_MODE=auto
AI_PROVIDER_TIMEOUT_SECONDS=45
AI_PROVIDER_MAX_RETRIES=2

# ─── Model Discovery ──────────────────────────────────────────────────────────
MODEL_DISCOVERY_ENABLED=true
MODEL_DISCOVERY_REFRESH_SECONDS=3600
MODEL_AUTO_SELECTION_ENABLED=true

# ─── GPU ──────────────────────────────────────────────────────────────────────
GPU_ENABLED=true
GPU_REQUIRED=false
GPU_PROVIDER=nvidia
GPU_DEVICE=auto
CUDA_VISIBLE_DEVICES=0
NVIDIA_VISIBLE_DEVICES=all
NVIDIA_DRIVER_CAPABILITIES=compute,utility
GPU_ALLOW_CPU_FALLBACK=true
GPU_MEMORY_SOFT_LIMIT_MB=0
GPU_MEMORY_HARD_LIMIT_MB=0
GPU_PREFER_HALF_PRECISION=true
GPU_ENABLE_MIXED_PRECISION=true

# ─── Local LLM ────────────────────────────────────────────────────────────────
LOCAL_LLM_ENABLED=false
LOCAL_LLM_GPU_ENABLED=true
LOCAL_LLM_RUNTIME=auto
LOCAL_LLM_BASE_URL=
LOCAL_LLM_MODEL_CACHE_DIR=./data/models
LOCAL_LLM_MAX_CONTEXT_TOKENS=8192

# ─── STT ──────────────────────────────────────────────────────────────────────
STT_ENABLED=true
STT_ENGINE=faster_whisper
STT_GPU_ENABLED=true
STT_DEVICE=auto
STT_COMPUTE_TYPE=auto
STT_MODEL_SIZE=base
STT_BATCH_SIZE=1

# ─── TTS ──────────────────────────────────────────────────────────────────────
TTS_ENABLED=true
TTS_ENGINE=auto
TTS_GPU_ENABLED=auto
TTS_DEVICE=auto
TTS_MODEL_CACHE_DIR=./data/tts

# ─── Voice ────────────────────────────────────────────────────────────────────
VOICE_STREAMING_ENABLED=true

# ─── Embeddings ───────────────────────────────────────────────────────────────
EMBEDDINGS_ENABLED=true
EMBEDDINGS_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDINGS_GPU_ENABLED=true
EMBEDDINGS_DEVICE=auto
EMBEDDINGS_BATCH_SIZE=32

# ─── FAISS ────────────────────────────────────────────────────────────────────
FAISS_ENABLED=true
FAISS_GPU_ENABLED=false
FAISS_INDEX_PATH=./data/faiss/index
FAISS_GPU_DEVICE=0

# ─── Vision ───────────────────────────────────────────────────────────────────
VISION_ENABLED=true
VISION_GPU_ENABLED=true
VISION_DEVICE=auto
VISION_MODEL_CACHE_DIR=./data/vision

# ─── GPU Workload Flags ───────────────────────────────────────────────────────
RAG_GPU_ACCELERATION_ENABLED=true
MEMORY_SYNTHESIS_GPU_ENABLED=true
BATCH_AI_GPU_ENABLED=true

# ─── Search ───────────────────────────────────────────────────────────────────
WEB_SEARCH_ENABLED=true
DEEP_SEARCH_ENABLED=true

# ─── Semantic Cache ───────────────────────────────────────────────────────────
SEMANTIC_CACHE_ENABLED=true
SEMANTIC_CACHE_THRESHOLD=0.95
SEMANTIC_CACHE_TTL_SECONDS=86400

# ─── Sandbox ──────────────────────────────────────────────────────────────────
SANDBOX_ENABLED=true
SANDBOX_NETWORK_DISABLED=true
SANDBOX_CPU_LIMIT=1.0
SANDBOX_MEMORY_LIMIT=512m
SANDBOX_TIMEOUT_SECONDS=30
SANDBOX_OUTPUT_LIMIT_BYTES=200000
SANDBOX_GPU_ENABLED=false

# ─── Local PC Control ─────────────────────────────────────────────────────────
LOCAL_PC_CONTROL_ENABLED=true
LOCAL_ADMIN_ACTIONS_REQUIRE_APPROVAL=true

# ─── Self-Improvement ─────────────────────────────────────────────────────────
SELF_IMPROVEMENT_ENABLED=true
SELF_IMPROVEMENT_REQUIRE_APPROVAL=true
SELF_VERSIONING_ENABLED=true

# ─── Observability ────────────────────────────────────────────────────────────
PROMETHEUS_ENABLED=true
OTEL_ENABLED=true
OTEL_SERVICE_NAME=jarvis-backend
JAEGER_ENDPOINT=http://jaeger:14268/api/traces

# ─── Security / CORS ──────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:5173,tauri://localhost
REQUEST_RATE_LIMIT_PER_MINUTE=120
